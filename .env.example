# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
ALLOWED_USER_IDS=  # comma-separated

# Executor: 'api' (DeepSeek/OpenAI) or 'auth' (Claude CLI)
EXECUTOR_TYPE=api

# API Executor (when EXECUTOR_TYPE=api)
API_KEY=sk-xxx
API_BASE_URL=https://api.deepseek.com
API_MODEL=deepseek-chat
API_MAX_TOKENS=4096
API_TEMPERATURE=0.7
SYSTEM_PROMPT=  # optional system prompt

# Claude CLI Executor (when EXECUTOR_TYPE=auth)
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=
MAX_TURNS=50
MAX_TURN_DURATION_MS=1800000

# Session
SESSION_DATA_DIR=./data/sessions
IDLE_TIMEOUT_MS=3600000
MAX_HISTORY_MESSAGES=200

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
