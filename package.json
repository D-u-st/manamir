    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
