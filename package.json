  "homepage": "https://github.com/YOUR_GITHUB_USER/manamir#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_GITHUB_USER/manamir.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB_USER/manamir/issues"
  },
  "files": [
